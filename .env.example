# Baserow (solo servidor — nunca NEXT_PUBLIC para el token)
BASEROW_API_URL=https://db.odenix.shop/api
BASEROW_API_TOKEN=

# IDs de tablas Baserow
BASEROW_TABLE_CLIENTES=616
BASEROW_TABLE_USUARIOS_ACCESO=
BASEROW_TABLE_PRODUCTOS=617
BASEROW_TABLE_BANNERS=618

# Tabla Eventos_Interaccion (Tipo, Detalle, Total, Estado, Cliente link → Clientes)
BASEROW_TABLE_EVENTOS_INTERACCION=

# Opcional: IDs de opciones single select en Eventos_Interaccion (si Baserow no acepta texto)
# BASEROW_EVENTO_TIPO_PEDIDO_OPTION_ID=
# BASEROW_EVENTO_TIPO_CITA_OPTION_ID=
# BASEROW_EVENTO_ESTADO_PENDIENTE_OPTION_ID=
# BASEROW_EVENTO_ESTADO_COMPLETADO_OPTION_ID=

# Opcional: IDs numéricos de las opciones del single select Tipo_de_Plantilla (tabla Clientes).
# Si Baserow rechaza el texto "Catálogo"/"Citas", copia los IDs desde la definición del campo.
# BASEROW_PLANTILLA_OPTION_CATALOGO_ID=
# BASEROW_PLANTILLA_OPTION_CITAS_ID=

# Webhook n8n: notificaciones al crear pedido/cita (POST JSON desde el portal)
# N8N_WEBHOOK_URL=https://n8n.tudominio.com/webhook/odenix-pedidos

# JWT de sesión del portal (mínimo 32 caracteres aleatorios en producción)
SESSION_SECRET=9de60e5392987a445b5ec5e468894c491ffecb9c6017fff2e4c31f31114126c5